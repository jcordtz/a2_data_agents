# =============================================================================
# Example Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and update with your values.
#
# PREREQUISITES:
# 1. An existing Key Vault with the following secrets configured:
#    - Oracle: oracle-host, oracle-username, oracle-password
#    - MSSQL: mssql-host, mssql-username, mssql-password
#    - PostgreSQL: postgres-host, postgres-username, postgres-password
#    - IBM DB2: ibmdb2-host, ibmdb2-username, ibmdb2-password
#
# 2. Existing databases accessible from Azure
# 3. Microsoft Purview (if using Purview integration)
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings (Required)
# -----------------------------------------------------------------------------
resource_group_name = "dataagent-rg"
location            = "eastus"
base_name           = "dataagent"

tags = {
  Environment = "Development"
  Project     = "DataAgent"
  ManagedBy   = "Terraform"
}

# -----------------------------------------------------------------------------
# Existing Key Vault (Required)
# -----------------------------------------------------------------------------
# Name of the Key Vault containing database secrets
key_vault_name = "YOUR_KEY_VAULT_NAME"

# Resource group of the Key Vault (leave empty if same as resource_group_name)
key_vault_resource_group = ""

# -----------------------------------------------------------------------------
# Azure OpenAI Settings
# -----------------------------------------------------------------------------
openai_deployment_name = "gpt-4o"
openai_model_name      = "gpt-4o"
openai_model_version   = "2024-05-13"
openai_capacity        = 10

# -----------------------------------------------------------------------------
# Oracle Database Settings
# (host, username, password come from Key Vault secrets)
# -----------------------------------------------------------------------------
oracle_port         = "1521"
oracle_service_name = "ORCL"

# -----------------------------------------------------------------------------
# Microsoft SQL Server Settings
# (host, username, password come from Key Vault secrets)
# -----------------------------------------------------------------------------
mssql_port               = "1433"
mssql_database           = ""
mssql_trusted_connection = false

# -----------------------------------------------------------------------------
# PostgreSQL Settings
# (host, username, password come from Key Vault secrets)
# -----------------------------------------------------------------------------
postgres_port     = "5432"
postgres_database = ""

# -----------------------------------------------------------------------------
# IBM DB2 LUW Settings
# (host, username, password come from Key Vault secrets)
# -----------------------------------------------------------------------------
ibmdb2_port     = "50000"
ibmdb2_database = ""

# -----------------------------------------------------------------------------
# Chatbot Settings (Optional)
# -----------------------------------------------------------------------------
deploy_chatbot         = false
chatbot_mcp_server_url = ""  # Leave empty to use Function App URL
chatbot_sku            = "Free"  # "Free" or "Standard"
