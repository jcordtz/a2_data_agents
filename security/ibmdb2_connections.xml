         Host: sales-db.example.com (matches sample_tables.csv)
         ======================================================================== -->
    <connection id="db2_sales_db_example_sales" type="db2" auth="password">
        <description>Sales Database - Password Authentication</description>
        <host>sales-db.example.com</host>
        <port>50000</port>
        <database>SALESDB</database>
        <schema>SALES</schema>
        <credentials>
            <username>sales_readonly</username>
            <password>your-secure-password-here</password>
