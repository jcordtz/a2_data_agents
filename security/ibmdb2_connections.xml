            <security>SSL</security>
            <ssl_client_keystoredb>/opt/ibm/ssl/client.kdb</ssl_client_keystoredb>
            <ssl_client_keystash>/opt/ibm/ssl/client.sth</ssl_client_keystash>
            <min_connections>1</min_connections>
            <max_connections>5</max_connections>
            <connect_timeout>30</connect_timeout>
        </options>
    </connection>

