{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "PREREQUISITES: An existing Key Vault with database secrets (oracle-host, oracle-username, oracle-password, mssql-*, postgres-*, ibmdb2-*), existing databases, and Microsoft Purview (if using Purview integration).",
  "parameters": {
    "baseName": {
      "value": "dataagent"
    },
    "location": {
      "value": "eastus"
    },
    "openAIDeploymentName": {
      "value": "gpt-4o"
    },
    "keyVaultName": {
      "value": "YOUR_KEY_VAULT_NAME"
    },
    "oraclePort": {
      "value": "1521"
    },
    "oracleServiceName": {
      "value": "ORCL"
    },
    "mssqlPort": {
      "value": "1433"
    },
    "mssqlDatabase": {
      "value": ""
    },
    "mssqlTrustedConnection": {
      "value": false
    },
    "postgresPort": {
      "value": "5432"
    },
    "postgresDatabase": {
      "value": ""
    },
    "ibmdb2Port": {
      "value": "50000"
    },
    "ibmdb2Database": {
      "value": ""
    },
    "deployChatbot": {
      "value": false
    },
    "chatbotMcpServerUrl": {
      "value": ""
    },
    "chatbotSku": {
      "value": "Free"
    }
  }
}
